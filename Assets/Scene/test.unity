    \u043B\u043E\u0431\u043E\u0432\u043E\u0435\n\u043F\u0440\u0438\u0432\u044B\u043B\u0430\u0437\u0430\u043D\u044C\u0438/\u0437\u0430\u043B\u0430\u0437\u0430\u043D\u044C\u0438
    \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0442\u044C
    \u043A\u0430\u043C\u0435\u0440\u0443 \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443
    \u0434\u0432\u0435\u0440\u0438\n\n\u043D\u0443\u0436\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0442\u043E\u0447\u043A\u0438 \u043A \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0435\u0434\u0443\u0442 \u043C\u0430\u0448\u0438\u043D\u044B (\u0435\u0434\u0435\u0442
    \u043D\u0435 \u043A \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435 \u0430 \u0442\u0443\u0434\u0430 \u0433\u0434\u0435
    \u043F\u043E \u043F\u0440\u0435\u043C\u043E\u0439 \u043A\u043B\u0430\u0441\u0441
    \u0441 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435\u043C \u0442\u043E\u0447\u0435\u043A)\n\n\u0432\u0441\u044F\u043A\u0430\u044F
    \u0432\u0441\u044F\u0447\u0438\u043D\u0430 \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435\n\u043F\u043E\u0434\u0431\u043E\u0440
    \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0438\n\u0430\u0431\u0430\u0440\u0434\u0430\u0436\n\n\u043C\u0435\u0442\u0430
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u044F \u0438\u043B\u0438
    \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u0431\u0435\u0434\u0443 \u0432 \u0433\u043E\u043D\u043A\u0430\u0445
    \u0438\u043B\u0438 \u0447\u0435\u0440\u0435\u0437 \u0432\u044B\u043B\u0430\u0437\u0435\u0438
    \u043D\u0430 \u0441\u0432\u0430\u043B\u043A\u0443\n\u043D\u0430 \u0442\u0440\u0430\u0441\u0441\u0435
    \u043C\u043E\u0436\u043D\u043E \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u043D\u043E\u0432\u0443\u044E
    \u0442\u0430\u0447\u043A\u0443 \u0438\u0437 \u0437\u0430\u0430\u043F\u0447\u0430\u0441\u0442\u0435\u0439
    \u0442\u0430\u0447\u0435\u043A \u0441 \u043F\u0440\u0435\u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0433\u043E\u043D\u043E\u043A\n"
