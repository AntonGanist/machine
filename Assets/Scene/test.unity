    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0432\u0440\u0430\u0433\n1 \u0431\u0435\u0436\u0430\u0442\u044C \u0434\u043E
    \u0444\u0438\u043D\u0438\u0448\u0430 (\u043E\u0434\u043D\u043E \u0438\u0437 \u0434\u0435\u0444\u043E\u043B\u0442\u043D\u044B\u0445)\n2
    \u0431\u0435\u0433\u0441\u0442\u0432\u043E (\u0440\u0435\u0430\u043A\u0446\u0438\u044F
    \u043D\u0430 \u0432\u0440\u0430\u0433\u0430) \u043F\u043E\u0442\u043E\u043C \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
    \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435\n3 \u043F\u0440\u044F\u0442\u0430\u0442\u044C\u0441\u044F
    (\u0440\u0435\u0430\u043A\u0446\u0438\u044F \u043D\u0430 \u0432\u0440\u0430\u0433\u0430)
    \n4 \u0447\u0438\u043D\u0438\u0442\u044C \u043C\u0430\u0448\u0438\u043D\u0443
    (\u043E\u0434\u043D\u043E \u0438\u0437 \u0434\u0435\u0444\u043E\u043B\u0442\u043D\u044B\u0445)\n5
    \u0441\u0442\u0430\u0432\u0438\u0442\u044C \u043B\u043E\u0432\u0443\u0448\u043A\u0438
    (\u043E\u0434\u043D\u043E \u0438\u0437 \u0434\u0435\u0444\u043E\u043B\u0442\u043D\u044B\u0445)\n6
    \u0441\u0440\u0430\u0436\u0430\u0442\u044C\u0441\u044F (\u0440\u0435\u0430\u043A\u0446\u0438\u044F
    \u043D\u0430 \u0432\u0440\u0430\u0433\u0430)"
